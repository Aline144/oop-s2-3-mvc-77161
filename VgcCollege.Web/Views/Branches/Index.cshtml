@model IEnumerable<VgcCollege.Web.Models.Branch>

@{
    ViewData["Title"] = "Branches";
}

<h1>Branches</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Branch</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var branch in Model)
    {
        <tr>
            <td>@branch.Name</td>
            <td>@branch.Address</td>
            <td>
                <a asp-action="Details" asp-route-id="@branch.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@branch.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@branch.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>