@model IEnumerable<VgcCollege.Web.Models.Assignment>

@{
    ViewData["Title"] = "Assignments";
}

<h1>Assignments</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Assignment</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Title</th>
        <th>Course</th>
        <th>Max Score</th>
        <th>Due Date</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var assignment in Model)
    {
        <tr>
            <td>@assignment.Title</td>
            <td>@assignment.Course?.Name</td>
            <td>@assignment.MaxScore</td>
            <td>@assignment.DueDate.ToShortDateString()</td>
            <td>
                <a asp-action="Details" asp-route-id="@assignment.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@assignment.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@assignment.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>