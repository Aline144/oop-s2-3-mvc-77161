@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>

@{
    ViewData["Title"] = "Assignment Results";
}

<h1>Assignment Results</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Assignment Result</a>
</p>

@if (Model == null || !Model.Any())
{
    <p>No assignment results found.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Assignment</th>
            <th>Student</th>
            <th>Score</th>
            <th>Feedback</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var result in Model)
        {
            <tr>
                <td>@result.Assignment?.Title</td>
                <td>@result.StudentProfile?.Name</td>
                <td>@result.Score</td>
                <td>@result.Feedback</td>
                <td>
                    <a asp-action="Details" asp-route-id="@result.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@result.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@result.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}