@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Create Assignment Result";
}

<h1>Create Assignment Result</h1>

<h4>Assignment Result</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label">Assignment</label>
                <select asp-for="AssignmentId" class="form-control" asp-items="ViewBag.AssignmentId"></select>
                <span asp-validation-for="AssignmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Feedback" class="form-label"></label>
                <input asp-for="Feedback" class="form-control" />
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}