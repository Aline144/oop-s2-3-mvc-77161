@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>

@{
    ViewData["Title"] = "Course Enrolments";
}

<h1>Course Enrolments</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Enrolment</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Student</th>
        <th>Course</th>
        <th>Enrol Date</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var enrolment in Model)
    {
        <tr>
            <td>@enrolment.StudentProfile?.Name</td>
            <td>@enrolment.Course?.Name</td>
            <td>@enrolment.EnrolDate.ToShortDateString()</td>
            <td>@enrolment.Status</td>
            <td>
                <a asp-action="Details" asp-route-id="@enrolment.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@enrolment.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@enrolment.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>