@model IEnumerable<VgcCollege.Web.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Attendance Record</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Student</th>
        <th>Course</th>
        <th>Date</th>
        <th>Present</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var attendance in Model)
    {
        <tr>
            <td>@attendance.CourseEnrolment?.StudentProfile?.Name</td>
            <td>@attendance.CourseEnrolment?.Course?.Name</td>
            <td>@attendance.Date.ToShortDateString()</td>
            <td>@(attendance.Present ? "Yes" : "No")</td>
            <td>
                <a asp-action="Details" asp-route-id="@attendance.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@attendance.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@attendance.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>