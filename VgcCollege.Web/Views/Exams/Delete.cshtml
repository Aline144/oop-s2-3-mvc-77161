@model VgcCollege.Web.Models.Exam

@{
    ViewData["Title"] = "Delete Exam";
}

<h1>Delete Exam</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Exam</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.Course?.Name</dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>

        <dt class="col-sm-2">Max Score</dt>
        <dd class="col-sm-10">@Model.MaxScore</dd>

        <dt class="col-sm-2">Results Released</dt>
        <dd class="col-sm-10">@(Model.ResultsReleased ? "Yes" : "No")</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>