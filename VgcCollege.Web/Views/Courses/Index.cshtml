@model IEnumerable<VgcCollege.Web.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1>Courses</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Course</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Branch</th>
        <th>Start Date</th>
        <th>End Date</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.Name</td>
            <td>@course.Branch?.Name</td>
            <td>@course.StartDate.ToShortDateString()</td>
            <td>@course.EndDate.ToShortDateString()</td>
            <td>
                <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>