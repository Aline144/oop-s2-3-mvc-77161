@model VgcCollege.Web.Models.ExamResult

@{
    ViewData["Title"] = "Edit Exam Result";
}

<h1>Edit Exam Result</h1>

<h4>Exam Result</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="ExamId" class="form-label">Exam</label>
                <select asp-for="ExamId" class="form-control" asp-items="ViewBag.ExamId"></select>
                <span asp-validation-for="ExamId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Grade" class="form-label"></label>
                <input asp-for="Grade" class="form-control" />
                <span asp-validation-for="Grade" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}